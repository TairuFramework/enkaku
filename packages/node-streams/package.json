{
  "name": "@enkaku/node-streams",
  "version": "0.19.0",
  "license": "MIT",
  "homepage": "https://enkaku.dev",
  "description": "Node Streams transport for Enkaku RPC clients and servers",
  "keywords": [
    "transport",
    "rpc",
    "node",
    "streams",
    "ipc"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TairuFramework/enkaku",
    "directory": "packages/node-streams"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib/*"
  ],
  "sideEffects": false,
  "scripts": {
    "build:clean": "del lib",
    "build:js": "swc src -d ./lib --config-file ../../node_modules/@kigu/dev/swc.json --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --skipLibCheck",
    "build": "pnpm run build:clean && pnpm run build:js && pnpm run build:types",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "test:unit": "vitest run",
    "test": "pnpm run test:types && pnpm run test:unit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@sozai/stream": "catalog:",
    "@enkaku/transport": "workspace:^"
  }
}
