{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "clean": {},
    "build:js": {
      "dependsOn": ["^build:js"],
      "outputs": ["lib/**"]
    },
    "build:types": {
      "dependsOn": ["^build:types"],
      "outputs": ["lib/**/*.d.ts", "*.tsbuildinfo"]
    },
    "test:types": {
      "dependsOn": ["^build:types"]
    },
    "test:unit": {
      "dependsOn": ["^build:js"]
    }
  }
}
